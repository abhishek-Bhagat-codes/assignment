```gitignore
# Dependencies
node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build folders
dist/
build/
out/

# Coverage reports
coverage/

# Cache
.cache/
.parcel-cache/
.eslintcache

# React / Vite
.vite/

# Next.js
.next/

# Temporary files
tmp/
temp/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Debug files
*.tgz

# Optional npm cache
.npm/

# Optional Yarn files
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Optional PNPM
.pnpm-store/

# SQLite databases (if used)
*.sqlite
*.sqlite3
*.db

# Testing
.nyc_output/

# TypeScript
*.tsbuildinfo
```
